{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": ".test-output",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "src/components/project/projectInteractions.ts",
    "src/components/project/stringListEdit.ts",
    "src/components/provider/providerSchedule.ts",
    "src/components/skill/visibility.ts",
    "src/components/sync/pathDisplay.ts",
    "src/components/sync/schedule.ts",
    "src/components/sync/systemRecords.ts",
    "src/components/sync/taskRules.ts",
    "src/lib/query/client.ts",
    "src/lib/query/projectDeletion.ts",
    "src/lib/query/projectSymlinkInventory.ts",
    "tests/**/*.test.ts"
  ],
  "exclude": ["dist", "node_modules", ".test-output"]
}
